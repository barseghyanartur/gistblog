&lt;h3&gt;.zshrc&lt;/h3&gt;
&lt;div class="highlight"&gt;&lt;pre&gt;&lt;span&gt;&lt;/span&gt;# ----------------------------------------------------------------------------
# CudaText
# ----------------------------------------------------------------------------
alias cudatext=&amp;quot;/Applications/CudaText.app/Contents/MacOS/cudatext&amp;quot;
&lt;/pre&gt;&lt;/div&gt;
&lt;/div&gt;
